<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">


  <!-- Create appointment table -->
  <changeSet author="cabs-app" failOnError="false" id="1" runOnChange="true">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="appointment"/>
      </not>
    </preConditions>
    <sqlFile path="db/changelog/table/appointment.sql"/>
  </changeSet>

  <!-- Create jhi_authority table -->
  <changeSet author="jhi_authority" failOnError="false" id="2" runOnChange="true">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="jhi_authority"/>
      </not>
    </preConditions>
    <sqlFile path="db/changelog/table/jhi_authority.sql"/>
  </changeSet>

  <!-- Create jhi_user table -->
  <changeSet author="cabs-app" failOnError="false" id="3" runOnChange="true">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="jhi_user"/>
      </not>
    </preConditions>
    <sqlFile path="db/changelog/table/jhi_user.sql"/>
  </changeSet>

  <!-- Create jhi_user_authority table -->
  <changeSet author="cabs-app" failOnError="false" id="4" runOnChange="true">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="jhi_user_authority"/>
      </not>
    </preConditions>
    <sqlFile path="db/changelog/table/jhi_user_authority.sql"/>
  </changeSet>

  <!-- Create patient table -->
  <changeSet author="cabs-app" failOnError="false" id="5" runOnChange="true">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="patient"/>
      </not>
    </preConditions>
    <sqlFile path="db/changelog/table/patient.sql"/>
  </changeSet>

</databaseChangeLog>
